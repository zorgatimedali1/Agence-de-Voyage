# ============================================================
# ZORGATI VOYAGE — Variables d'environnement
# Copiez ce fichier en ".env" et remplissez vos valeurs réelles
# Ne commitez jamais le fichier .env dans Git !
# ============================================================

# Port du serveur Express
PORT=3000

# URI de connexion MongoDB Atlas
# Remplacez <username>, <password> et <cluster-url> par vos valeurs réelles
# Exemple : mongodb+srv://zorgati_user:MonMotDePasse@zorgaticlusters.abc12.mongodb.net/zorgati_voyage?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/zorgati_voyage?retryWrites=true&w=majority

# Environnement : development | production
NODE_ENV=development
